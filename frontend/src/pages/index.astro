---
import presentationContract from "../data/generated/presentation-contract.json";
import layoutContract from "../data/generated/layout-contract.json";
import editorialChapters from "../data/generated/editorial-chapters.json";
import {
  buildTimelineContract,
  buildTimelineLayout,
  describeTimelineRow,
  getDefaultUiState,
  getTimelineViewportMetrics,
  normalizeTimelineUiState,
  renderTimelineScene,
  type TimelineContract,
} from "../lib/timeline";

const timelineContract = buildTimelineContract(
  presentationContract,
  layoutContract,
  editorialChapters,
) as TimelineContract;
const chapters = [...(timelineContract.editorial?.story_chapters ?? [])].sort(
  (left, right) => left.chapter_order - right.chapter_order,
);
const initialState = normalizeTimelineUiState(timelineContract, getDefaultUiState(timelineContract, null));
const initialViewport = getTimelineViewportMetrics(timelineContract, initialState);
const initialLayout = buildTimelineLayout(timelineContract, initialState);
const initialSummaryRow = initialLayout.nodes.find((row) => row.visible) ?? initialLayout.edges[0];
const sceneMarkup = renderTimelineScene(initialLayout);
const initialChapterPreview = initialLayout.scene.chapters[0] ?? null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Memphis Asset Lineage Atlas</title>
    <meta
      name="description"
      content="Graph-dominant Memphis asset lineage renderer driven by the generated presentation and layout contracts."
    />
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <div class="masthead__copy">
          <p class="eyebrow">Stage 8 • Chapter navigation and minimap integration</p>
          <h1>Memphis asset lineage as a living graph.</h1>
          <p class="lede">
            Chapter focus windows and minimap jumps now ride on the same bounded viewport model. The graph stays first;
            chapter navigation simply repositions that existing chronology window with contract-owned anchors.
          </p>
        </div>
        <div class="masthead__meta">
          <div class="meta-card">
            <span>Nodes</span>
            <strong>{timelineContract.meta.node_count}</strong>
          </div>
          <div class="meta-card">
            <span>Edges</span>
            <strong>{timelineContract.meta.edge_count}</strong>
          </div>
          <div class="meta-card">
            <span>Window</span>
            <strong>{initialState.windowStart}</strong>
            <small>{initialState.windowEnd}</small>
          </div>
          <div class="meta-card">
            <span>Visible days</span>
            <strong id="window-days">{initialViewport.windowDays}</strong>
            <small>30 to 180 day bounds</small>
          </div>
        </div>
      </header>

      <section class="atlas">
        <div class="atlas__header">
          <div>
            <p class="atlas__eyebrow">Renderer state</p>
            <h2>Graph-first traversal with chapter-assisted jumps</h2>
            <p class="atlas__copy">
              Scroll across the chronology window first, then jump through minimap anchors or chapter focus windows
              without leaving the viewport semantics established in T8.
            </p>
          </div>
          <div class="legend" aria-label="Band legend">
            <span class="legend__item legend__item--main_roster">Main roster</span>
            <span class="legend__item legend__item--two_way">Two-way</span>
            <span class="legend__item legend__item--future_picks">Future picks</span>
          </div>
        </div>

        <div class="controls">
          <div class="control-group">
            <h3>Asset type</h3>
            <div class="button-row" data-control="asset-kind">
              <button type="button" class="chip is-active" data-kind="all">All assets</button>
              <button type="button" class="chip" data-kind="player_tenure">Players</button>
              <button type="button" class="chip" data-kind="pick_continuity">Picks</button>
            </div>
          </div>
          <div class="control-group">
            <h3>Date window</h3>
            <div class="date-row">
              <label>
                Start
                <input id="window-start" type="date" value={initialState.windowStart} />
              </label>
              <label>
                End
                <input id="window-end" type="date" value={initialState.windowEnd} />
              </label>
            </div>
          </div>
          <div class="control-group">
            <h3>Zoom</h3>
            <input id="zoom" type="range" min={initialViewport.minZoom} max={initialViewport.maxZoom} step="0.05" value={initialState.zoom} />
            <div class="range-labels">
              <span>Wider window</span>
              <span>Tighter window</span>
            </div>
            <p class="control-note" id="zoom-state">
              {initialViewport.windowDays} visible days
            </p>
          </div>
        </div>

        <div class="story-nav">
          <div class="story-nav__copy">
            <p class="atlas__eyebrow">Story chapters</p>
            <h3>Focus the graph through generated chapter windows</h3>
            <p class="control-note">
              Chapter identity and copy stay editorial. Window bounds, minimap anchors, and optional zoom come from
              <code>chapter_layout</code>.
            </p>
          </div>
          <div class="chapter-strip" id="chapter-strip" aria-label="Chapter navigation">
            {initialLayout.scene.chapters.map((chapter) => (
              <button
                type="button"
                class="chapter-chip"
                data-chapter-id={chapter.story_chapter_id}
                aria-label={`Focus chapter ${chapter.chapter_order}: ${chapter.title}`}
              >
                <span class="chapter-chip__index">{String(chapter.chapter_order).padStart(2, "0")}</span>
                <span class="chapter-chip__body">
                  <strong>{chapter.title}</strong>
                  <small>{chapter.windowStart} to {chapter.windowEnd}</small>
                </span>
              </button>
            ))}
          </div>
        </div>

        <div class="atlas__frame">
          <div class="atlas__summary">
            <div>
              <p class="atlas__eyebrow">Scene focus</p>
              <strong id="timeline-summary">{describeTimelineRow(initialSummaryRow)}</strong>
            </div>
            <p>
              Use horizontal wheel or trackpad motion over the graph to progress the viewport, then use chapters or the
              minimap to land on contract-owned focus anchors without changing graph semantics.
            </p>
          </div>

          <div class="atlas__navigation">
            <article class="focus-card">
              <p class="atlas__eyebrow">Active focus window</p>
              <strong id="chapter-focus-title">Viewport-driven overview</strong>
              <p id="chapter-focus-copy">
                Select a chapter or minimap segment to bind the current viewport to a generated navigation target.
              </p>
              <small id="chapter-focus-range">{initialState.windowStart} to {initialState.windowEnd}</small>
            </article>

            <div class="minimap">
              <div class="minimap__header">
                <div>
                  <p class="atlas__eyebrow">Chronology minimap</p>
                  <strong>Jump with layout-owned anchor segments</strong>
                </div>
                <small id="minimap-status">{initialState.windowStart} to {initialState.windowEnd}</small>
              </div>
              <div class="minimap__track">
                <div class="minimap__focus is-hidden" id="minimap-focus-window"></div>
                <div class="minimap__segments" id="minimap-segments">
                  {initialLayout.scene.chronology.minimapSegments.map((segment) => (
                    <button
                      type="button"
                      class="minimap-segment"
                      data-segment-id={segment.segment_id}
                      data-linked-chapter-id={segment.linkedChapterIds[0] ?? ""}
                      aria-label={`Jump to ${segment.label}`}
                    >
                      <span class="minimap-segment__label">{segment.label}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div class="timeline-shell" id="timeline-shell" tabindex="0" aria-label="Horizontal timeline viewport">
            <svg
              id="timeline-svg"
              viewBox={`0 0 ${initialLayout.width} ${initialLayout.height}`}
              width={initialLayout.width}
              height={initialLayout.height}
              role="img"
              aria-label="Memphis asset lineage graph"
            >
              <g id="timeline-scene" set:html={sceneMarkup}></g>
            </svg>
          </div>
        </div>
      </section>

      <section class="support">
        <article class="panel panel--chapter">
          <p class="atlas__eyebrow">Navigation contract</p>
          <h2>{initialChapterPreview?.title ?? "No chapter export loaded"}</h2>
          <p>
            This phase wires chapter identity to layout-owned focus windows and minimap anchors. Full graph-adjacent
            chapter presentation stays intentionally deferred.
          </p>
          <small>
            {initialChapterPreview
              ? `${initialChapterPreview.windowStart} to ${initialChapterPreview.windowEnd}`
              : "No chapter focus window available."}
          </small>
        </article>

        <article class="panel panel--state">
          <p class="atlas__eyebrow">Artifact state</p>
          <div class="context-list">
            <div class="context-card">
              <strong>Presentation contract</strong>
              <span>{timelineContract.meta.presentation_build_id as string}</span>
            </div>
            <div class="context-card">
              <strong>Layout contract</strong>
              <span>{timelineContract.layout?.layout_meta.start_date} to {timelineContract.layout?.layout_meta.end_date}</span>
            </div>
            <div class="context-card">
              <strong>Editorial export</strong>
              <span>{chapters.length} chapter payload loaded with layout-driven navigation active.</span>
            </div>
          </div>
        </article>

        <section class="panel panel--inspector">
          <div class="inspector-header">
            <div>
              <p class="atlas__eyebrow">Inspector</p>
              <h2>Payload details</h2>
              <p id="inspector-summary">Hover or click a visible node or strand to inspect its payload.</p>
            </div>
            <button type="button" class="ghost" id="clear-selection">Clear</button>
          </div>
          <pre id="inspector-body">{JSON.stringify(timelineContract.meta, null, 2)}</pre>
        </section>
      </section>
    </main>

    <script type="application/json" id="stage8-contract" is:inline set:html={JSON.stringify(timelineContract)}></script>
    <script type="application/json" id="stage8-initial-state" is:inline set:html={JSON.stringify(initialState)}></script>
    <script>
      import {
        activateTimelineChapter,
        buildTimelineLayout,
        describeTimelineRow,
        getTimelineViewportMetrics,
        jumpTimelineToMinimapSegment,
        normalizeTimelineUiState,
        renderTimelineScene,
        setTimelineViewportWindow,
        setTimelineZoomLevel,
        shiftTimelineViewport,
        type AssetKind,
        type TimelineContract,
        type TimelineUiState,
      } from "../lib/timeline";

      type SelectionState = { kind: "node" | "edge"; id: string } | null;

      const contract = JSON.parse(document.getElementById("stage8-contract")?.textContent ?? "{}") as TimelineContract;
      const initialState = JSON.parse(document.getElementById("stage8-initial-state")?.textContent ?? "{}") as TimelineUiState;
      const timelineShell = document.getElementById("timeline-shell") as HTMLDivElement;
      const timeline = document.getElementById("timeline-svg") as unknown as SVGSVGElement;
      const scene = document.getElementById("timeline-scene") as unknown as SVGGElement;
      const summary = document.getElementById("timeline-summary") as HTMLElement;
      const inspectorSummary = document.getElementById("inspector-summary") as HTMLElement;
      const inspectorBody = document.getElementById("inspector-body") as HTMLElement;
      const startInput = document.getElementById("window-start") as HTMLInputElement;
      const endInput = document.getElementById("window-end") as HTMLInputElement;
      const zoomInput = document.getElementById("zoom") as HTMLInputElement;
      const zoomState = document.getElementById("zoom-state") as HTMLElement;
      const windowDays = document.getElementById("window-days") as HTMLElement;
      const chapterFocusTitle = document.getElementById("chapter-focus-title") as HTMLElement;
      const chapterFocusCopy = document.getElementById("chapter-focus-copy") as HTMLElement;
      const chapterFocusRange = document.getElementById("chapter-focus-range") as HTMLElement;
      const minimapStatus = document.getElementById("minimap-status") as HTMLElement;
      const minimapFocusWindow = document.getElementById("minimap-focus-window") as HTMLDivElement;
      const clearButton = document.getElementById("clear-selection") as HTMLButtonElement;
      const assetButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-control="asset-kind"] .chip'));
      const chapterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-chapter-id]"));
      const minimapButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-segment-id]"));

      let state: TimelineUiState = normalizeTimelineUiState(contract, {
        ...initialState,
        assetKinds: initialState.assetKinds ?? ["player_tenure", "pick_continuity"],
      });
      let selected: SelectionState = null;

      function setInspector(title: string, payload: unknown) {
        inspectorSummary.textContent = title;
        inspectorBody.textContent = JSON.stringify(payload, null, 2);
      }

      function inspectableTarget(event: Event): HTMLElement | null {
        const element = event.target instanceof Element ? event.target : null;
        return element?.closest<HTMLElement>("[data-inspectable='true']") ?? null;
      }

      function setAssetKinds(kind: string) {
        state.assetKinds = kind === "all" ? ["player_tenure", "pick_continuity"] : [kind as AssetKind];
        for (const button of assetButtons) {
          button.classList.toggle("is-active", button.dataset.kind === kind);
        }
        render();
      }

      function syncTimelineSize(layout: ReturnType<typeof buildTimelineLayout>) {
        timeline.setAttribute("viewBox", `0 0 ${layout.width} ${layout.height}`);
        timeline.setAttribute("width", String(layout.width));
        timeline.setAttribute("height", String(layout.height));
      }

      function syncViewportControls(viewport: ReturnType<typeof getTimelineViewportMetrics>) {
        startInput.value = viewport.windowStart;
        endInput.value = viewport.windowEnd;
        zoomInput.min = String(viewport.minZoom);
        zoomInput.max = String(viewport.maxZoom);
        zoomInput.value = String(viewport.zoom);
        zoomState.textContent = `${viewport.windowDays} visible days`;
        windowDays.textContent = String(viewport.windowDays);
        timelineShell.style.maxWidth = `${viewport.viewportWidth}px`;
      }

      function syncFocusWindow(layout: ReturnType<typeof buildTimelineLayout>) {
        const activeFocus = layout.scene.activeFocus;
        if (!activeFocus) {
          minimapFocusWindow.classList.add("is-hidden");
          minimapFocusWindow.style.removeProperty("--focus-start");
          minimapFocusWindow.style.removeProperty("--focus-width");
          return;
        }

        const trackExtent = (layout.scene.chronology.minimapSegments.at(-1)?.x2 ?? layout.width - layout.scene.rightPad) - layout.scene.leftPad;
        const start = ((activeFocus.windowX1 - layout.scene.leftPad) / Math.max(1, trackExtent)) * 100;
        const end = ((activeFocus.windowX2 - layout.scene.leftPad) / Math.max(1, trackExtent)) * 100;
        minimapFocusWindow.classList.remove("is-hidden");
        minimapFocusWindow.style.setProperty("--focus-start", `${Math.max(0, Math.min(100, start))}%`);
        minimapFocusWindow.style.setProperty("--focus-width", `${Math.max(3, Math.min(100, end) - Math.max(0, start))}%`);
      }

      function syncChapterNavigation(layout: ReturnType<typeof buildTimelineLayout>) {
        const activeChapterId = layout.scene.activeFocus?.story_chapter_id ?? null;
        const activeSegmentIds = new Set(
          layout.scene.chronology.minimapSegments
            .filter((segment) => segment.active)
            .map((segment) => segment.segment_id),
        );
        const activeAnchorLabel = layout.scene.activeFocus?.minimapAnchorId
          ? layout.scene.chronology.minimapSegments.find((segment) => segment.segment_id === layout.scene.activeFocus?.minimapAnchorId)?.label ?? null
          : null;

        for (const button of chapterButtons) {
          button.classList.toggle("is-active", button.dataset.chapterId === activeChapterId);
        }

        for (const button of minimapButtons) {
          button.classList.toggle("is-active", activeSegmentIds.has(button.dataset.segmentId ?? ""));
          button.classList.toggle("is-anchor", Boolean(button.dataset.linkedChapterId));
        }

        if (layout.scene.activeFocus) {
          chapterFocusTitle.textContent = layout.scene.activeFocus.title;
          chapterFocusCopy.textContent = activeAnchorLabel
            ? `Bound to ${activeAnchorLabel} while preserving the existing viewport model.`
            : "Bound to the chapter focus window while preserving the existing viewport model.";
          chapterFocusRange.textContent = `${layout.scene.activeFocus.windowStart} to ${layout.scene.activeFocus.windowEnd}`;
          minimapStatus.textContent = activeAnchorLabel ?? `${layout.scene.chronology.windowStart} to ${layout.scene.chronology.windowEnd}`;
        } else {
          chapterFocusTitle.textContent = "Viewport-driven overview";
          chapterFocusCopy.textContent = "Use chapter chips or minimap segments to reposition the current viewport without switching navigation models.";
          chapterFocusRange.textContent = `${layout.scene.chronology.windowStart} to ${layout.scene.chronology.windowEnd}`;
          minimapStatus.textContent = `${layout.scene.chronology.windowStart} to ${layout.scene.chronology.windowEnd}`;
        }

        syncFocusWindow(layout);
      }

      function resolveSummaryRow(layout: ReturnType<typeof buildTimelineLayout>) {
        return layout.nodes.find((row) => row.focused)
          ?? layout.nodes.find((row) => row.visible)
          ?? layout.edges.find((row) => row.visible)
          ?? layout.nodes[0]
          ?? layout.edges[0];
      }

      function render(): ReturnType<typeof buildTimelineLayout> {
        state = normalizeTimelineUiState(contract, state);
        const viewport = getTimelineViewportMetrics(contract, state);
        const layout = buildTimelineLayout(contract, state);
        syncTimelineSize(layout);
        syncViewportControls(viewport);
        syncChapterNavigation(layout);
        scene.innerHTML = renderTimelineScene(layout);

        const summaryRow = resolveSummaryRow(layout);
        summary.textContent = describeTimelineRow(summaryRow);

        const currentSelection = selected;
        const selectedNodeVisible = currentSelection?.kind === "node"
          ? layout.nodes.some((row) => row.node_id === currentSelection.id)
          : false;
        const selectedEdgeVisible = currentSelection?.kind === "edge"
          ? layout.edges.some((row) => row.edge_id === currentSelection.id)
          : false;
        selected = selectedNodeVisible || selectedEdgeVisible ? selected : null;

        const retainedSelection = selected;
        if (retainedSelection?.kind === "node") {
          const current = layout.nodes.find((row) => row.node_id === retainedSelection.id);
          if (current) {
            setInspector(`Node ${current.label}`, current);
          }
        } else if (retainedSelection?.kind === "edge") {
          const current = layout.edges.find((row) => row.edge_id === retainedSelection.id);
          if (current) {
            setInspector(`Edge ${current.edge_id}`, current);
          }
        }

        return layout;
      }

      function inspectNode(nodeId: string, locked = false) {
        const layout = buildTimelineLayout(contract, state);
        const node = layout.nodes.find((row) => row.node_id === nodeId);
        if (!node) {
          return;
        }
        if (locked) {
          selected = { kind: "node", id: nodeId };
        }
        setInspector(`${locked ? "Selected" : "Preview"} node`, node);
        summary.textContent = describeTimelineRow(node);
      }

      function inspectEdge(edgeId: string, locked = false) {
        const layout = buildTimelineLayout(contract, state);
        const edge = layout.edges.find((row) => row.edge_id === edgeId);
        if (!edge) {
          return;
        }
        if (locked) {
          selected = { kind: "edge", id: edgeId };
        }
        setInspector(`${locked ? "Selected" : "Preview"} edge`, edge);
        summary.textContent = `${edge.edge_type} · ${edge.asset_id}`;
      }

      timeline.addEventListener("pointerover", (event) => {
        const target = inspectableTarget(event);
        if (!target) {
          return;
        }
        if (target.dataset.kind === "node") {
          inspectNode(target.dataset.nodeId ?? "");
        } else if (target.dataset.kind === "edge") {
          inspectEdge(target.dataset.edgeId ?? "");
        }
      });

      timeline.addEventListener("focusin", (event) => {
        const target = inspectableTarget(event);
        if (!target) {
          return;
        }
        if (target.dataset.kind === "node") {
          inspectNode(target.dataset.nodeId ?? "");
        } else if (target.dataset.kind === "edge") {
          inspectEdge(target.dataset.edgeId ?? "");
        }
      });

      timeline.addEventListener("click", (event) => {
        const target = inspectableTarget(event);
        if (!target) {
          return;
        }
        if (target.dataset.kind === "node") {
          inspectNode(target.dataset.nodeId ?? "", true);
        } else if (target.dataset.kind === "edge") {
          inspectEdge(target.dataset.edgeId ?? "", true);
        }
      });

      assetButtons.forEach((button) => {
        button.addEventListener("click", () => setAssetKinds(button.dataset.kind ?? "all"));
      });

      chapterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const chapterId = button.dataset.chapterId;
          if (!chapterId) {
            return;
          }
          state = activateTimelineChapter(contract, state, chapterId);
          render();
        });
      });

      minimapButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const segmentId = button.dataset.segmentId;
          if (!segmentId) {
            return;
          }
          state = jumpTimelineToMinimapSegment(contract, state, segmentId);
          render();
        });
      });

      startInput.addEventListener("change", () => {
        state = setTimelineViewportWindow(contract, state, startInput.value, endInput.value);
        render();
      });

      endInput.addEventListener("change", () => {
        state = setTimelineViewportWindow(contract, state, startInput.value, endInput.value);
        render();
      });

      zoomInput.addEventListener("input", () => {
        state = setTimelineZoomLevel(contract, state, Number(zoomInput.value));
        render();
      });

      timelineShell.addEventListener("wheel", (event) => {
        const primaryDelta = Math.abs(event.deltaX) >= Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        if (primaryDelta === 0) {
          return;
        }
        event.preventDefault();
        const viewport = getTimelineViewportMetrics(contract, state);
        const deltaDays = Math.sign(primaryDelta) * Math.max(1, Math.round(Math.abs(primaryDelta) / viewport.viewportWidth * viewport.windowDays));
        state = shiftTimelineViewport(contract, state, deltaDays);
        render();
      }, { passive: false });

      clearButton.addEventListener("click", () => {
        selected = null;
        setInspector("Selection cleared", contract.meta);
      });

      render();
    </script>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    color: #f7f1e8;
    background:
      radial-gradient(circle at top left, rgba(15, 118, 110, 0.24), transparent 32%),
      radial-gradient(circle at right, rgba(194, 120, 58, 0.18), transparent 28%),
      linear-gradient(180deg, #071016 0%, #0a141b 56%, #060b10 100%);
    font-family: "IBM Plex Sans", "Avenir Next", "Segoe UI", sans-serif;
  }

  .shell {
    max-width: 1600px;
    margin: 0 auto;
    padding: 28px 22px 40px;
  }

  .masthead,
  .atlas,
  .panel,
  .control-group,
  .meta-card {
    border: 1px solid rgba(216, 243, 255, 0.12);
    background: rgba(7, 18, 26, 0.76);
    backdrop-filter: blur(18px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.22);
  }

  .masthead {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 420px);
    gap: 24px;
    padding: 24px;
    border-radius: 28px;
  }

  .eyebrow,
  .atlas__eyebrow {
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #f1c46f;
    font-size: 0.74rem;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: "Iowan Old Style", "Palatino Linotype", Georgia, serif;
    font-weight: 600;
  }

  h1 {
    max-width: 11ch;
    font-size: clamp(2.9rem, 5vw, 5.8rem);
    line-height: 0.92;
  }

  h2 {
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
  }

  h3 {
    font-size: 0.94rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(247, 241, 232, 0.7);
  }

  .lede,
  .atlas__copy {
    margin: 16px 0 0;
    max-width: 70ch;
    color: rgba(247, 241, 232, 0.78);
    line-height: 1.6;
  }

  .masthead__meta {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    align-content: end;
  }

  .meta-card {
    padding: 16px;
    border-radius: 18px;
  }

  .meta-card span,
  .meta-card small {
    display: block;
    color: rgba(247, 241, 232, 0.64);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
  }

  .meta-card strong {
    display: block;
    margin-top: 8px;
    font-size: 1.8rem;
    line-height: 1.05;
  }

  .atlas {
    margin-top: 20px;
    padding: 22px;
